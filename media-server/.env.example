PORT=3000

# Supabase admin (service role) — used to write media_analysis to nodes.data
# and upsert weave_embeddings rows. SUPABASE_URL is also where auth.ts pulls
# the JWKS from (/auth/v1/.well-known/jwks.json) to verify ES256 access
# tokens, so it must match the project that issued the user's session.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key — same model family as the main app.
GEMINI_API_KEY=

# Supadata API key for transcript fetches. Server fetches its own
# transcripts rather than reading from Supabase (see README §2).
SUPADATA_API_KEY=

# CORS allow-list (comma-separated). The browser preflights every
# /process POST because of the Authorization + JSON content-type combo,
# so any origin that needs to call this server must be listed here.
# Defaults to Vite's local dev origin if unset.
#   Local dev:   http://localhost:5173
#   Production:  https://your-netlify-site.netlify.app (set via fly secrets)
WEAVE_ALLOWED_ORIGINS=http://localhost:5173
