PORT=3000

# Supabase admin (service role) — used to write media_analysis to nodes.data
# and upsert weave_embeddings rows.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret from Supabase project settings → API → JWT Settings.
# Used to verify the user's access token on /process requests.
SUPABASE_JWT_SECRET=

# Gemini API key — same model family as the main app.
GEMINI_API_KEY=

# Supadata API key for transcript fetches. Server fetches its own
# transcripts rather than reading from Supabase (see README §2).
SUPADATA_API_KEY=
