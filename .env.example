VITE_ANTHROPIC_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Fly media server — POST /process kicks off the multimodal pipeline for
# YouTube and Twitter video nodes. Leave unset to disable the trigger
# (client-side text embedding still fires as the fallback).
#   Local dev: http://localhost:3000  (run `npm run dev` in media-server/)
#   Production: set in Netlify env vars to the deployed Fly URL.
VITE_WEAVE_MEDIA_URL=
